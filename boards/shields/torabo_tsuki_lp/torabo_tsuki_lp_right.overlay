#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/keys.h>
#include <mouse-gesture.dtsi>

// ジェスチャは base 入力チェーン(transform → zip_mouse_gesture → scaler)に置く。
// suppress-movement は base チェーンでのみ STOP がカーソル抑制に効く（override 子ノード
// では listener が STOP を握り潰すため効かない）。OS 別の出力は profile-morph behavior
// が担当し、Mac(profile 0)と Windows で別キーを送る。
// pattern は transform 後の座標＝画面の見た目どおりの向き。

/ {
    behaviors {
        // 各方向の OS 別出力（bindings[0]=Mac / [1]=Windows）
        gesture_next: gesture_next {
            compatible = "zmk,behavior-profile-morph";
            #binding-cells = <0>;
            // 右スワイプ: 次のスペース(Ctrl+→) / 次の仮想デスクトップ(Win+Ctrl+→)
            bindings = <&kp LC(RIGHT)>, <&kp LG(LC(RIGHT))>;
        };

        gesture_prev: gesture_prev {
            compatible = "zmk,behavior-profile-morph";
            #binding-cells = <0>;
            // 左スワイプ: 前のスペース(Ctrl+←) / 前の仮想デスクトップ(Win+Ctrl+←)
            bindings = <&kp LC(LEFT)>, <&kp LG(LC(LEFT))>;
        };

        gesture_up: gesture_up {
            compatible = "zmk,behavior-profile-morph";
            #binding-cells = <0>;
            // 上スワイプ: Mission Control(Ctrl+↑) / タスクビュー(Win+Tab)
            bindings = <&kp LC(UP)>, <&kp LG(TAB)>;
        };

        gesture_down: gesture_down {
            compatible = "zmk,behavior-profile-morph";
            #binding-cells = <0>;
            // 下スワイプ: デスクトップを表示(F11) / デスクトップ表示(Win+D)
            bindings = <&kp F11>, <&kp LG(D)>;
        };
    };
};

&zip_mouse_gesture {
    suppress-movement;   // ジェスチャ認識中はカーソルを動かさない
    stroke-size = <40>;  // 1ストロークに必要な移動量。小さいほど少ない動きで反応

    swipe_right {
        // 右スワイプ
        pattern = <GESTURE_RIGHT>;
        bindings = <&gesture_next>;
    };

    swipe_left {
        // 左スワイプ
        pattern = <GESTURE_LEFT>;
        bindings = <&gesture_prev>;
    };

    swipe_up {
        // 上スワイプ
        pattern = <GESTURE_UP>;
        bindings = <&gesture_up>;
    };

    swipe_down {
        // 下スワイプ
        pattern = <GESTURE_DOWN>;
        bindings = <&gesture_down>;
    };
};

&pointing_listener {
    input-processors = <
        &zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)
        &zip_mouse_gesture
        &zip_xy_scaler 3 10
    >;

    scroller {
        layers = <3>;
        // base のスクロール: Mac(profile 0) 向けに Y を反転
        process-next;
        input-processors = <
            &zip_xy_to_scroll_mapper
            &zip_scroll_transform (INPUT_TRANSFORM_Y_INVERT)
            &zip_scroll_scaler 1 20
        >;
    };

    //  Windows(profile != 0) ではスクロールの反転を打ち消す。
    scroller_win {
        layers = <2>;
        process-next;
        input-processors = <&zip_scroll_transform (INPUT_TRANSFORM_Y_INVERT)>;
    };
};

&size_s_transform {
    col-offset = <7>;
};

&size_m_transform {
    col-offset = <7>;
};

&size_l_transform {
    col-offset = <7>;
};